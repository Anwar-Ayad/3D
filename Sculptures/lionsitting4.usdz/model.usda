def Scope "Materials"
{

    def Material "Light_iron_001"
    {
        def Shader "PreviewSurface"
        {
            uniform token info:id = "UsdPreviewSurface"
            color3f inputs:diffuseColor = (0.0071880752220749855, 0.1345500946044922, 0.5053541660308838)
            normal3f inputs:normal.connect = </Materials/Light_iron_001/Texture_28_normal.outputs:rgb>
            float inputs:roughness.connect = </Materials/Light_iron_001/Texture_31_roughness.outputs:g>
            float inputs:metallic.connect = </Materials/Light_iron_001/Texture_30_metallic.outputs:b>
            float inputs:opacity = 1
            int inputs:useSpecularWorkflow = 0
            token outputs:surface
        }
        token outputs:surface.connect = </Materials/Light_iron_001/PreviewSurface.outputs:surface>
        token inputs:frame:stPrimvarName = "st"
        def Shader "uvReader_st"
        {
            uniform token info:id = "UsdPrimvarReader_float2"
            token inputs:varname.connect = </Materials/Light_iron_001.inputs:frame:stPrimvarName>
            float2 inputs:fallback = (0.0, 0.0)
            float2 outputs:result
        }

      def Shader "Transform2d_normal" (
          sdrMetadata = {
              string role = "math"
          }
      )
      {
          uniform token info:id = "UsdTransform2d"
          float2 inputs:in.connect = </Materials/Light_iron_001/uvReader_st.outputs:result>
          float2 inputs:scale = (4.909999847412109, 4.909999847412109)
          float2 inputs:translation = (0, -3.9099998474121094)
          float2 outputs:result
      }
      def Shader "Texture_28_normal"
      {
          uniform token info:id = "UsdUVTexture"
          asset inputs:file = @textures/Texture_28.png@
          float2 inputs:st.connect = </Materials/Light_iron_001/Transform2d_normal.outputs:result>
          float4 inputs:scale = (2.0, 2.0, 2.0, 1.0)
          float4 inputs:bias = (-1.0, -1.0, -1.0, 0.0)
          token inputs:wrapS = "repeat"
          token inputs:wrapT = "repeat"
          float outputs:a
          float3 outputs:rgb
      }

      def Shader "Transform2d_roughness" (
          sdrMetadata = {
              string role = "math"
          }
      )
      {
          uniform token info:id = "UsdTransform2d"
          float2 inputs:in.connect = </Materials/Light_iron_001/uvReader_st.outputs:result>
          float2 inputs:scale = (4.909999847412109, 4.909999847412109)
          float2 inputs:translation = (0, -3.9099998474121094)
          float2 outputs:result
      }
      def Shader "Texture_31_roughness"
      {
          uniform token info:id = "UsdUVTexture"
          asset inputs:file = @textures/Texture_31.png@
          float2 inputs:st.connect = </Materials/Light_iron_001/Transform2d_roughness.outputs:result>
          float4 inputs:scale = (1.0, 1.0, 1.0, 1.0)
          float4 inputs:bias = (0.0, 0.0, 0.0, 0.0)
          token inputs:wrapS = "repeat"
          token inputs:wrapT = "repeat"
          float outputs:a
          float3 outputs:rgb
      }

      def Shader "Transform2d_metallic" (
          sdrMetadata = {
              string role = "math"
          }
      )
      {
          uniform token info:id = "UsdTransform2d"
          float2 inputs:in.connect = </Materials/Light_iron_001/uvReader_st.outputs:result>
          float2 inputs:scale = (4.909999847412109, 4.909999847412109)
          float2 inputs:translation = (0, -3.9099998474121094)
          float2 outputs:result
      }
      def Shader "Texture_30_metallic"
      {
          uniform token info:id = "UsdUVTexture"
          asset inputs:file = @textures/Texture_30.png@
          float2 inputs:st.connect = </Materials/Light_iron_001/Transform2d_metallic.outputs:result>
          float4 inputs:scale = (1.0, 1.0, 1.0, 1.0)
          float4 inputs:bias = (0.0, 0.0, 0.0, 0.0)
          token inputs:wrapS = "repeat"
          token inputs:wrapT = "repeat"
          float outputs:a
          float3 outputs:rgb
      }
    }

